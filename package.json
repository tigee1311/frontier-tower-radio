  "description": "A communal radio station for the tower",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "react-scripts start",
    "build": "react-scripts build"
  },
  "proxy": "http://localhost:3001",
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "better-sqlite3": "^11.7.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "tailwindcss": "^3.4.0",
    "uuid": "^10.0.0",
    "youtube-sr": "^4.3.12",
    "ytsr": "^3.8.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
